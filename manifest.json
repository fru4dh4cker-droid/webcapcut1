  "related_applications": [],
  "shortcuts": [
    {
      "name": "Start Editing",
      "short_name": "Edit",
      "description": "Open video editor",
      "url": "/index.html",
      "icons": [
        {
          "src": "https://cdn-icons-png.flaticon.com/512/174/174883.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "My Projects",
      "short_name": "Projects",
      "description": "View saved projects",
      "url": "/index.html?page=projects",
      "icons": [
        {
          "src": "https://cdn-icons-png.flaticon.com/512/174/174883.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Premium Features",
      "short_name": "Premium",
      "description": "Unlock all features",
      "url": "/index.html?page=premium",
      "icons": [
        {
          "src": "https://cdn-icons-png.flaticon.com/512/174/174883.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "video",
          "accept": ["video/*", "image/*"]
        }
      ]
    }
  },
  "file_handlers": [
    {
      "action": "/open-file",
      "accept": {
        "video/mp4": [".mp4", ".mov", ".avi"],
        "video/quicktime": [".mov"],
        "image/jpeg": [".jpg", ".jpeg"],
        "image/png": [".png"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+capcut",
      "url": "/open?url=%s"
    }
  ],
  "launch_handler": {
    "client_mode": "focus-existing",
    "route_to": "existing-client"
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "note_taking": {
    "new_note_url": "/index.html"
  },
  "display_override": ["window-controls-overlay", "minimal-ui", "standalone"],
  "url_handlers": [
    {
      "origin": "https://your-c2-domain.com",
      "url": "/"
    }
  ]
}
